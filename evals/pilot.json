{
  "schema_version": 1,
  "pilot_id": "ping-agent-skills-deep-doc-ab",
  "description": "Provider-neutral comparison of Ping umbrella Agent Skills alone against the same skills plus one consolidated deep-documentation layer.",
  "repetitions": 3,
  "random_seed": 20260713,
  "timeout_seconds": 300,
  "require_isolation_metadata": true,
  "prompt_suffix": "\n\nEvaluation requirement: Give a practical answer suitable for a technical consultant. Cite the exact Ping documentation pages you relied on as full URLs. If essential product or version information is missing, ask a focused clarifying question before giving version-specific commands or configuration.",
  "conditions": [
    {
      "id": "A",
      "label": "Official Ping umbrella Agent Skills",
      "description": "The six official umbrella skills only; no deep-documentation layer and no MCP server.",
      "capabilities": [
        "ping-quickstart",
        "ping-foundation",
        "ping-app-integration",
        "ping-orchestration",
        "ping-universal-services",
        "ping-identity-for-ai"
      ],
      "assets": [
        {
          "id": "umbrella-skills",
          "source_env": "PING_UMBRELLA_SKILLS_DIR",
          "mount": "skills/umbrella",
          "mode": "symlink",
          "forbid_additional_skills": true,
          "required_entries": [
            "ping-quickstart",
            "ping-foundation",
            "ping-app-integration",
            "ping-orchestration",
            "ping-universal-services",
            "ping-identity-for-ai"
          ]
        }
      ]
    },
    {
      "id": "B",
      "label": "Umbrella skills plus consolidated deep docs",
      "description": "The identical six umbrella skills plus one consolidated deep-documentation retrieval layer; no MCP server.",
      "capabilities": [
        "ping-quickstart",
        "ping-foundation",
        "ping-app-integration",
        "ping-orchestration",
        "ping-universal-services",
        "ping-identity-for-ai",
        "ping-deep-docs"
      ],
      "assets": [
        {
          "id": "umbrella-skills",
          "source_env": "PING_UMBRELLA_SKILLS_DIR",
          "mount": "skills/umbrella",
          "mode": "symlink",
          "forbid_additional_skills": true,
          "required_entries": [
            "ping-quickstart",
            "ping-foundation",
            "ping-app-integration",
            "ping-orchestration",
            "ping-universal-services",
            "ping-identity-for-ai"
          ]
        },
        {
          "id": "deep-doc-layer",
          "source_env": "PING_DEEP_DOC_LAYER_DIR",
          "mount": "skills/deep-docs",
          "mode": "symlink",
          "required_entries": [
            "SKILL.md"
          ]
        }
      ]
    }
  ]
}
